# Connection string for your managed PostgreSQL database (e.g., Neon Tech)
DATABASE_URL=postgresql://[user]:[password]@[host]/[dbname]?sslmode=require

# API port configuration
PORT=5000

# Secret key used for signing session JSON Web Tokens (can be any string)
JWT_SECRET=super_secret_jwt_key_123

# Frontend URL required for strict CORS matching when utilizing HTTP-only cookies
FRONTEND_URL=http://localhost:5173
